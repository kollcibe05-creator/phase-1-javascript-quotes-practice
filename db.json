{
  "quotes": [
    {
      "id": "778e",
      "quote": "Ownership is everything. Own your mind and mind your own.",
      "author": "Nipsey Hustle"
    },
    {
      "id": "9bb2",
      "quote": "No such thing as a life that's better than yours",
      "author": "J Cole"
    },
    {
      "id": "6f00",
      "quote": "Words are nothing more than a sound if everything is pronounced without any intention",
      "author": "Kendrick Lamar"
    },
    {
      "id": "c6fc",
      "quote": "You can do anything you set your mind to man",
      "author": "Eminem"
    },
    {
      "id": "770b",
      "quote": "Until you make the unconscious conscious, it will direct your life and you will call it fate",
      "author": "Carl Jung"
    },
    {
      "id": "0b51",
      "quote": "The consequences of an act affect the probability of its occurring again.",
      "author": "B.F. Skinner"
    },
    {
      "id": "41ec",
      "quote": "When we are no longer able to change a situation, we are challenged to change ourselves.",
      "author": "Viktor Frankl"
    },
    {
      "id": "c774",
      "quote": "What a man can be, he must be.",
      "author": "Abraham Maslow"
    },
    {
      "id": "f3de",
      "quote": "The line between good and evil is permeable and almost anyone can be induced to cross it.",
      "author": "Philip Zimbardo"
    },
    {
      "id": "6078",
      "quote": "The greatest discovery of my generation is that a human being can alter his life by altering his attitudes.",
      "author": "William James"
